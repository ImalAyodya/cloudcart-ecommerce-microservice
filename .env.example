# ─────────────────────────────────────────────────────────────────────────────
# CloudCart – Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── Docker Hub ────────────────────────────────────────────────────────────────
# Your Docker Hub username (e.g. johndoe)
DOCKER_HUB_USERNAME=your_dockerhub_username

# Image tag (default: latest)
TAG=latest

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Leave blank to use the local mongo container (mongodb://mongo:27017/<db>)
# Or replace with your MongoDB Atlas connection strings:
PRODUCT_MONGO_URI=mongodb://mongo:27017/productdb
USER_MONGO_URI=mongodb://mongo:27017/userdb
ORDER_MONGO_URI=mongodb://mongo:27017/orderdb

# ── User Service ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_strong_secret_key
TOKEN_EXPIRES_IN=7d

# ── Notification Service ──────────────────────────────────────────────────────
# Gmail address used to send emails
EMAIL_USER=your_gmail@gmail.com
# Gmail App Password (Account → Security → 2FA → App Passwords)
EMAIL_PASSWORD=your_gmail_app_password

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL that the browser uses to reach the API Gateway.
# When running locally with docker compose this should be http://localhost:3000
# On a server, replace with the public URL (e.g. https://api.yourdomain.com)
VITE_API_GATEWAY_URL=http://localhost:3000
